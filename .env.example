# Elasticsearch
ES_HOST=https://x.x.x.x:xxxx
ES_USERNAME= 
ES_PASSWORD= 
ES_INDEX=gkg
ES_VERIFY_SSL=false

# LLM
LLM_BASE_URL=http://x.x.x.x:xxxx/v1
#LLM_MODEL_NAME=Devstral-2-123B-Instruct-2512
LLM_MODEL_NAME=MiniMax-M2.1-AWQ
LLM_API_KEY=not-required

# Safety / pipeline limits
MAX_RESULT_DOCS=20
MAX_AGG_BUCKETS=50
QUERY_MAX_ATTEMPTS=3

# ChromaDB server mode
# Use the container-internal port when backend talks to the chromadb service on the Docker network.
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_SSL=false
CHROMA_COLLECTION=gkg_mapping
SCHEMA_EMBEDDING_MODEL=all-MiniLM-L6-v2